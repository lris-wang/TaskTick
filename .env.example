# ============================================================
# TaskTick 部署配置
# ============================================================

# 【必填】安全密钥（生成方式：python -c "import secrets; print(secrets.token_hex(32))"）
SECRET_KEY=your-secret-key-at-least-32-characters-long

# PostgreSQL 密码
POSTGRES_PASSWORD=tasktick_secret

# 前端 API 地址（生产环境填你的域名，nginx 会把 /api 反向代理到后端）
#   开发: http://127.0.0.1:8000（默认）
#   生产: https://tasktick.your-domain.com（填你的域名）
VITE_API_URL=https://tasktick.your-domain.com

# MinIO（可选，不填则文件上传功能不可用）
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Sentry DSN（可选，崩溃监控。从 Sentry 项目设置 → Client Keys 获取）
VITE_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# ============================================================
# Web Push VAPID 密钥（生产环境必须设置）
# ============================================================
# 生成方式：
#   python -c "from webpush import VAPID; priv, pub = VAPID.generate_keys(); print(priv.decode()); print(pub.decode())"
# 或使用 web-push-genkey CLI（pip install web-push）
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# VAPID_SUBJECT 是你的联系地址（mailto: 或 https:），用于标识你的服务器
VAPID_SUBJECT=mailto:notify@your-domain.com

# ============================================================
# CORS（生产环境必须限制为你的前端域名，多个用逗号分隔）
# ============================================================
# 开发：*（允许所有）
# 生产：https://tasktick.your-domain.com（替换为你的实际域名）
CORS_ORIGINS=*

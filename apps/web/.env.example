# ============================================================
# 前端环境变量示例
# ============================================================
# 复制为 .env.development.local 或 .env.production.local
# VITE_ 前缀的变量会被 Vite 嵌入构建产物（构建时读取）

# 开发环境 API 地址
VITE_API_URL=http://127.0.0.1:8000

# 生产环境 API 地址（构建命令：pnpm build --mode production）
# VITE_API_URL=https://tasktick.your-domain.com

# Sentry 崩溃监控（可选）
# VITE_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

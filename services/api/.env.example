# ============================================================
# JWT（生产环境必须修改，默认值仅供开发使用）
# ============================================================
JWT_SECRET_KEY=tasktick-dev-secret-change-in-production-please
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============================================================
# 数据库配置
# ============================================================
# 开发默认（SQLite，无需额外安装）
DATABASE_URL=sqlite+aiosqlite:///./tasktick.db

# 生产环境（PostgreSQL）
# DATABASE_URL=postgresql+asyncpg://tasktick:tasktick_secret@localhost:5432/tasktick_db
# DATABASE_POOL_SIZE=20
# DATABASE_MAX_OVERFLOW=30
# DATABASE_POOL_TIMEOUT=30
# DATABASE_SSL=prefer

# ============================================================
# Redis（可选；不配则禁用缓存 / 限流 / token 黑名单）
# ============================================================
# 生产环境（需先 docker compose up -d 启动 Redis 容器）
# REDIS_URL=redis://default:tasktick_redis@localhost:6379/0
# REDIS_PASSWORD=tasktick_redis
# REDIS_DB=0
# REDIS_MAX_CONNECTIONS=20

# ============================================================
# Rate Limiting（依赖 Redis，未配置 Redis 时自动禁用）
# ============================================================
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_REQUESTS=60
# RATE_LIMIT_WINDOW_SECONDS=60
# RATE_LIMIT_AUTH_REQUESTS=10

# ============================================================
# MinIO（可选；不配则 /api/v1/ai/files/* 返回 503）
# ============================================================
# 本地可运行: docker compose -f docker-compose.minio.yml up -d
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=tasktick-files
MINIO_SECURE=false
MINIO_REGION=
MINIO_PRESIGN_EXPIRY_SECONDS=3600
MINIO_MAX_UPLOAD_BYTES=20971520
